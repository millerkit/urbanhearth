{
  "name": "urbanhearth",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "build:preview": "SANITY_PREVIEW=true astro build --config astro.config.preview.mjs && node scripts/fix-preview-wrangler.mjs",
    "deploy:preview": "pnpm build:preview && wrangler deploy --config dist/server/wrangler.json",
    "sanity:dev": "sanity dev",
    "sanity:deploy": "sanity deploy",
    "sync:toast": "node scripts/sync-toast.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",
    "@portabletext/to-html": "^5.0.2",
    "@sanity/client": "^7.22.0",
    "astro": "^6.2.1",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "styled-components": "^6.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.59.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanity": "^5.24.0",
    "wrangler": "^4.88.0"
  }
}
