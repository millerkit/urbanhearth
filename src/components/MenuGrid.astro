---
import { Image } from 'astro:assets';
import menus from '../content/menus.json';
import menuImage from '../assets/menus/spring-2026.png';

interface MenuItem {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  items?: MenuItem[];
}

const {
  eyebrow = 'Menus',
  items = menus,
} = Astro.props;
---

<section class="menus-section">
  <p class="section-eyebrow menus-eyebrow">{eyebrow}</p>
  <div class="menu-grid">
    {items.map(({ label, href }) => (
      <a href={href} class="menu-card">
        <div class="menu-card-label">{label}</div>
        <div class="menu-card-photo">
          <Image src={menuImage} alt={label} loading="lazy" />
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .menus-section {
    background: var(--cream);
  }

  .menus-eyebrow {
    text-align: center;
    padding: 3.5rem 0 0;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    margin-top: 1.8rem;
  }

  .menu-card {
    background: var(--cream);
    cursor: pointer;
    text-decoration: none;
    display: block;
    transition: opacity 0.22s;
  }
  .menu-card:hover { opacity: 0.82; }

  .menu-card-label {
    padding: 1.4rem 2rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--warm-white);
  }

  .menu-card-photo {
    width: 100%;
    aspect-ratio: 3/5;
    overflow: hidden;
    background: var(--parchment);
  }

  .menu-card-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .menu-card:hover .menu-card-photo img {
    transform: scale(1.03);
  }

@media (max-width: 700px) {
    .menu-grid { grid-template-columns: 1fr; }
  }
</style>
