---
import restaurant from '../content/restaurant.json';

interface Props {
  label?: string;
  href?: string;
}

const {
  label = restaurant.reservations.label,
  href = restaurant.reservations.href,
} = Astro.props;
---
<a href={href} class="reservation-btn">{label}</a>

<style>
  .reservation-btn {
    display: block;
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    background: var(--cream);
    padding: 1.4rem 2rem;
    text-align: center;
    transition: opacity 0.2s;
  }

  .reservation-btn:hover { opacity: 0.6; }
</style>
