---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  /** Pass an array of {src, alt} objects. Falls back to placeholder cells. */
  images?: GalleryImage[];
  /** How many placeholder cells to show when no images are provided */
  placeholderCount?: number;
}

const { images, placeholderCount = 4 } = Astro.props;

const cells = images ?? Array.from({ length: placeholderCount }, (_, i) => ({ src: '', alt: '', _placeholder: true, _index: i }));
---

<section class="gallery-section">
  <div class="gallery-strip">
    {cells.map((cell: any) => (
      <div class="gallery-cell">
        {cell.src
          ? <Image src={cell.src} alt={cell.alt} loading="lazy" />
          : null
        }
      </div>
    ))}
  </div>
</section>

<style>
  .gallery-section {
    background: var(--warm-white);
  }

  .gallery-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .gallery-cell {
    aspect-ratio: 3/2;
    overflow: hidden;
    background: linear-gradient(135deg, var(--parchment) 0%, #d6d0cb 100%);
  }

  .gallery-cell:nth-child(3) {
    background: linear-gradient(135deg, var(--midnight) 0%, #1d2d43 100%);
  }

  .gallery-cell img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .gallery-cell:hover img { transform: scale(1.04); }

  @media (max-width: 700px) {
    .gallery-strip { grid-template-columns: 1fr; }
  }
</style>
