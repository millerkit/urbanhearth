---
interface Props {
  blok: {
    name?: string;
    price?: string;
    description?: string;
    note?: string;
  };
}

const { blok } = Astro.props;
---

<li class="dish">
  <div class="dish-top">
    <span class="dish-name">{blok.name}</span>
    <span class="dish-price">{blok.price}</span>
  </div>
  {blok.description && <p class="dish-desc">{blok.description}</p>}
  {blok.note && <p class="menu-fine-print dish-note">{blok.note}</p>}
</li>

<style>
  .dish {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .dish-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 0.4rem;
  }

  .dish-price {
    font-family: var(--sans), sans-serif;
    font-size: 16px;
    font-weight: 300;
    color: var(--ink-mid);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dish-note {
    margin-top: 0.5rem;
  }
</style>
