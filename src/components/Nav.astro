---
import links from "../content/nav-links.json";
import restaurant from "../content/restaurant.json";
import logo from "../assets/brand/UrbanHearth_Logo_BLACK_cropped.png";

const currentPath = Astro.url.pathname;

function isActive(item: { href: string; children?: { href: string }[] }) {
  if (currentPath === item.href) return true;
  return item.children?.some((c) => currentPath === c.href) ?? false;
}
---

<!-- Desktop nav -->
<nav id="site-nav">
  {
    links.map((item) =>
      item.children ? (
        <div
          class={`nav-item nav-item--dropdown${isActive(item) ? " active" : ""}`}
        >
          <a
            href={item.href}
            class={`nav-link${isActive(item) ? " active" : ""}`}
          >
            {item.label}
            <svg
              class="dropdown-caret"
              width="8"
              height="5"
              viewBox="0 0 8 5"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M1 1l3 3 3-3"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
          <div class="dropdown">
            {item.children.map((child) => (
              <a
                href={child.href}
                class={`dropdown-link${currentPath === child.href ? " active" : ""}`}
              >
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="nav-item">
          <a
            href={item.href}
            class={`nav-link${currentPath === item.href ? " active" : ""}`}
          >
            {item.label}
          </a>
        </div>
      ),
    )
  }
</nav>

<!-- Mobile overlay menu -->
<div
  id="mobile-menu"
  aria-hidden="true"
  role="dialog"
  aria-label="Navigation menu"
>
  <div class="mm-header">
    <div></div>
    <a href="/" class="mm-wordmark">
      <img src={logo.src} alt={restaurant.name} class="mm-logo" />
    </a>
  </div>

  <nav class="mm-nav">
    {
      links.map((item) => (
        <div class="mm-item">
          <a
            href={item.href}
            class={`mm-link${isActive(item) ? " active" : ""}`}
          >
            {item.label}
          </a>
          {item.children &&
            item.children.map((child) => (
              <a
                href={child.href}
                class={`mm-child${currentPath === child.href ? " active" : ""}`}
              >
                {child.label}
              </a>
            ))}
        </div>
      ))
    }
  </nav>

  <div class="mm-footer">
    <a href={restaurant.reservations.href} class="mm-reserve"
      >{restaurant.reservations.label}</a
    >
  </div>
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  function setMenu(open: boolean) {
    menu?.classList.toggle("is-open", open);
    menu?.setAttribute("aria-hidden", (!open).toString());

    toggle?.setAttribute("aria-expanded", open.toString());
    toggle?.classList.toggle("is-open", open);

    document.body.style.overflow = open ? "hidden" : "";
  }

  toggle?.addEventListener("click", (e) => {
    e.stopPropagation(); // 👈 prevents accidental close
    const isOpen = toggle.classList.contains("is-open");
    setMenu(!isOpen);
  });

  // Close when any link is clicked
  menu
    ?.querySelectorAll("a")
    .forEach((a) => a.addEventListener("click", () => setMenu(false)));
</script>

<style is:global>
  /* ── Desktop nav ── */
  #site-nav {
    position: fixed;
    top: 60px;
    left: 0;
    right: 0;
    z-index: 99;
    background: var(--warm-white);
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  #site-nav .nav-item {
    position: relative;
  }

  #site-nav .nav-link {
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;
  }

  #site-nav .nav-link::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--ink);
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  #site-nav .nav-link:hover::after,
  #site-nav .nav-link.active::after {
    transform: scaleX(1);
  }

  #site-nav .nav-link:hover {
    opacity: 0.6;
  }

  #site-nav .nav-link.active {
    opacity: 1;
  }

  #site-nav .dropdown-caret {
    opacity: 0.4;
    transition: transform 0.2s ease;
    flex-shrink: 0;
    position: relative;
    top: 1px;
  }

  #site-nav .nav-item--dropdown:hover .dropdown-caret {
    transform: rotate(180deg);
  }

  #site-nav .dropdown {
    position: absolute;
    top: calc(100% + 15px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    background: var(--warm-white);
    border: 1px solid var(--border);
    box-shadow: 0 8px 24px rgba(22, 34, 53, 0.08);
    min-width: 190px;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.18s ease,
      transform 0.18s ease,
      visibility 0s linear 0.18s;
    pointer-events: none;
    z-index: 100;
  }

  #site-nav .dropdown::before {
    content: "";
    position: absolute;
    top: -15px;
    left: 0;
    right: 0;
    height: 15px;
  }

  #site-nav .nav-item--dropdown:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease,
      visibility 0s linear 0s;
    pointer-events: auto;
  }

  #site-nav .dropdown-link {
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding: 0.9rem 1.5rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
    white-space: nowrap;
    display: block;
  }

  #site-nav .dropdown-link:last-child {
    border-bottom: none;
  }

  #site-nav .dropdown-link:hover {
    background: var(--parchment);
  }

  #site-nav .dropdown-link.active {
    background: var(--parchment);
  }

  /* ── Mobile: hide desktop nav, reduce page offset ── */
  @media (max-width: 700px) {
    #site-nav {
      display: none;
    }

    main > * {
      margin-top: 60px !important;
    }
  }

  /* ── Mobile overlay: hidden on desktop ── */
  #mobile-menu {
    display: none;
  }

  @media (max-width: 700px) {
    #mobile-menu {
      display: flex;
      flex-direction: column;
      position: fixed;
      inset: 0;
      z-index: 200;
      background: var(--warm-white);
      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.25s ease,
        visibility 0s linear 0.25s;
      overflow-y: auto;
    }

    #mobile-menu.is-open {
      opacity: 1;
      visibility: visible;
      transition: opacity 0.25s ease;
      z-index: 1;
    }

    .mm-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 0 1.25rem;
      height: 60px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .mm-wordmark {
      display: flex;
      align-items: center;
      text-align: center;
      text-decoration: none;
    }

    .mm-logo {
      height: 26px;
      width: auto;
      display: block;
      mix-blend-mode: multiply;
    }

    .mm-nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: 2rem 1.75rem 1rem;
    }

    .mm-item {
      display: contents;
    }

    .mm-link {
      font-family: var(--sans), sans-serif;
      font-size: 12px;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      padding: 1.1rem 0;
      border-bottom: 1px solid var(--border);
      display: block;
      transition: opacity 0.2s;
    }

    .mm-link:first-of-type {
      border-top: 1px solid var(--border);
    }

    .mm-link:hover {
      opacity: 0.5;
    }

    .mm-link.active {
      opacity: 0.5;
    }

    .mm-child {
      font-family: var(--sans), sans-serif;
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-mid);
      text-decoration: none;
      padding: 0.75rem 0 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
      display: block;
      transition: opacity 0.2s;
    }

    .mm-child:hover {
      opacity: 0.5;
    }

    .mm-child.active {
      opacity: 0.5;
    }

    .mm-footer {
      padding: 2rem 1.75rem;
      flex-shrink: 0;
    }

    .mm-reserve {
      display: block;
      font-family: var(--sans), sans-serif;
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      background: var(--cream);
      padding: 1.4rem 2rem;
      text-align: center;
      transition: opacity 0.2s;
    }

    .mm-reserve:hover {
      opacity: 0.6;
    }
  }
</style>
