---
import { getSiteSettings } from "../lib/site-settings";
import card from "../content/chefs-counter.json";
import "../styles/menu-shared.css";

const restaurant = await getSiteSettings();
---

<div class="menu-card card">
  <p class="menu-eyebrow">{card.eyebrow}</p>
  <div class="price">{card.price} <span>{card.priceLabel}</span></div>
  <p class="desc">{card.description}</p>
  <div class="sub-row">
    <span class="menu-label">{card.winePairingLabel}</span>
    <span class="sub-value">{card.winePairingValue}</span>
  </div>
  <ul class="courses">
    {
      card.courses.map((c) => (
        <li class="course">
          <span class="course-numeral">{c.label}</span>
          <span class="dish-name">{c.name}</span>
          {"desc" in c && <span class="dish-desc course-desc">{c.desc}</span>}
        </li>
      ))
    }
  </ul>
  <p class="menu-fine-print note">{card.finePrint}</p>
  <a href={`${restaurant.reservations.href}#chefs-counter`} class="cta"
    >Reserve your seat</a
  >
</div>

<style>
  .card {
    padding: 2.5rem 2rem;
  }

  .price {
    font-family: var(--serif), serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--midnight);
    line-height: 1;
    margin-bottom: 1.2rem;
  }

  .price span {
    font-family: var(--sans), sans-serif;
    font-size: 12px;
    font-weight: 300;
    color: var(--charcoal);
    letter-spacing: 0.1em;
  }

  .desc {
    font-family: var(--serif), serif;
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--midnight);
    margin-bottom: 1.5rem;
  }

  .sub-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.75rem 0;
    border-top: 1px solid rgba(22, 34, 53, 0.13);
    border-bottom: 1px solid rgba(22, 34, 53, 0.13);
    margin-bottom: 1.2rem;
  }

  .sub-value {
    font-family: var(--sans), sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: var(--midnight);
  }

  .courses {
    list-style: none;
    border-top: 1px solid rgba(22, 34, 53, 0.13);
    margin-bottom: 1.5rem;
  }

  .course {
    display: grid;
    grid-template-columns: 1.4rem 1fr;
    column-gap: 0.75rem;
    row-gap: 0.2rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(22, 34, 53, 0.13);
  }

  .course-numeral {
    font-family: var(--sans), sans-serif;
    font-size: 9px;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--charcoal);
    padding-top: 0.2rem;
    grid-row: 1 / 3;
    align-self: start;
  }

  .course-desc {
    grid-column: 2;
  }

  .note {
    margin-bottom: 1.8rem;
  }

  .cta {
    display: inline-block;
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--midnight);
    text-decoration: none;
    border-bottom: 1px solid rgba(22, 34, 53, 0.4);
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .cta:hover {
    opacity: 0.6;
  }
</style>
