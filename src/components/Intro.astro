---
import ReservationButton from "./ReservationButton.astro";

interface Props {
  eyebrow?: string;
  paragraphs?: string[];
}

const {
  eyebrow = "The Restaurant",
  paragraphs = [
    "Urban Hearth is a quiet refuge from the city — a place where seasonal cooking meets unhurried hospitality.",
    "Set across two floors overlooking the harbor, our kitchen works with a close network of New England farmers and fishermen to craft a menu that changes with the week's best produce.",
    "Everything is made in-house: the bread, the charcuterie, the preserves. Unpretentious but considered. Warm but precise.",
  ],
} = Astro.props;
---

<section class="intro">
  <p class="section-eyebrow">{eyebrow}</p>
  <div class="intro-body">
    {paragraphs.map((text) => <p>{text}</p>)}
    <div class="intro-cta"><ReservationButton /></div>
  </div>
</section>

<style>
  .intro {
    padding: 6rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--warm-white);
  }

  .section-eyebrow {
    margin-bottom: 2.5rem;
  }

  .intro-body {
    max-width: 560px;
  }

  .intro-body p {
    font-family: var(--serif), serif;
    font-size: 1.1875rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--ink);
    margin-bottom: 1.4rem;
  }

  .intro-body p:last-of-type {
    margin-bottom: 0;
  }

  .intro-cta {
    margin-top: 2.5rem;
  }
</style>
