---
import { getHomepageContent } from "../lib/homepage";

const homepage = await getHomepageContent();
const s = homepage.statement;
---

<section class="statement">
  <div class="statement-inner">
    <p class="statement-eyebrow section-eyebrow">{s.eyebrow}</p>
    <p class="statement-tags section-eyebrow">{s.tags}</p>

    <p class="statement-text">
      <em>{s.definitionTerm}</em>
      {s.definitionText}
    </p>

    <p class="statement-text">{s.description}</p>
  </div>
</section>

<style>
  /* ── Statement ── */
  .statement {
    background: var(--warm-white);
    border-bottom: 1px solid var(--border);
    padding: clamp(3rem, 5vw, 4rem) 1.5rem;
    text-align: center;
  }

  .statement-inner {
    max-width: clamp(560px, 65ch, 680px);
    margin: 0 auto;
  }

  .statement-eyebrow {
    margin-bottom: 0.75rem;
  }

  .statement-tags {
    color: var(--ink-mid);
    margin-bottom: 1.5rem;
  }

  .statement-text {
    font-family: var(--serif), serif;
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: 1.25rem;
  }

  .statement-text:last-child {
    margin-bottom: 0;
  }
</style>
