---
import restaurant from '../content/restaurant.json';
import logo from '../assets/brand/UrbanHearth_Logo_BLACK_cropped.png';
---

<div class="top-bar">
  <div class="top-bar-left">
    <span class="address">{restaurant.address}</span>
    <button class="menu-toggle" id="menu-toggle" aria-label="Open navigation menu" aria-expanded="false">Menu</button>
  </div>
  <a href="/" class="wordmark">
    <img src={logo.src} alt={restaurant.name} class="wordmark-logo" />
  </a>
  <div class="cta-wrap">
    <a href={restaurant.reservations.href} class="cta" target="_blank" rel="noopener">{restaurant.reservations.shortLabel}</a>
  </div>
</div>

<style>
  .top-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--warm-white);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 2rem;
    height: 52px;
    border-bottom: 1px solid var(--border);
  }

  .top-bar-left {
    display: flex;
    align-items: center;
  }

  .address {
    font-family: var(--sans),sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .menu-toggle {
    display: none;
    font-family: var(--sans), sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .wordmark {
    display: flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
  }

  .wordmark-logo {
    height: 26px;
    width: auto;
    display: block;
    mix-blend-mode: multiply;
  }

  .cta-wrap {
    display: flex;
    justify-content: flex-end;
  }

  .cta {
    font-family: var(--sans),sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .cta:hover { opacity: 0.55; }

  @media (max-width: 700px) {
    .top-bar { padding: 0 1.25rem; }
    .address { display: none; }
    .menu-toggle { display: block; }
  }
</style>
