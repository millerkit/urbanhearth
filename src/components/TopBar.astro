---
import { getSiteSettings } from "../lib/site-settings";
import logo from "../assets/brand/UrbanHearth_Logo_BLACK_cropped.png";

const restaurant = await getSiteSettings();
---

<div class="top-bar">
  <div class="top-bar-left">
    <span class="address">{restaurant.address}</span>
    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
    >
      <span class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>
  <a href="/" class="wordmark">
    <img src={logo.src} alt={restaurant.name} class="wordmark-logo" />
  </a>
  <div class="cta-wrap">
    <a
      href={restaurant.reservations.href}
      class="cta"
      target="_blank"
      rel="noopener"
    >
      <span class="cta-full">{restaurant.reservations.label}</span>
      <span class="cta-short">{restaurant.reservations.shortLabel}</span>
    </a>
  </div>
</div>

<style>
  .top-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--warm-white);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 2rem;
    height: 60px;
    border-bottom: 1px solid var(--border);
  }

  .top-bar-left {
    display: flex;
    align-items: center;
  }

  .address {
    font-family: var(--sans), sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    line-height: 0;

    position: relative; /* required for z-index to work */
    z-index: 100; /* sits above the mobile menu */
  }

  .menu-toggle.is-open .hamburger span {
    opacity: 0.85;
  }

  .menu-toggle:hover .hamburger span {
    opacity: 0.6;
    transform: scaleX(0.92);
  }

  /* Hamburger container */
  .hamburger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px; /* more breathing room = more elegant */
  }

  /* Lines */
  .hamburger span {
    display: block;
    width: 20px; /* slightly shorter */
    height: 1px; /* thinner = more refined */
    background-color: var(--ink);
    transition:
      transform 0.25s ease,
      opacity 0.2s ease;
    transform-origin: center;
  }

  /* Subtle hover effect */
  .menu-toggle:hover .hamburger span {
    opacity: 0.6;
  }

  .menu-toggle.is-open .hamburger span {
    background-color: var(--ink);
    opacity: 0.9;
  }

  /* OPEN STATE (add .is-open via JS) */
  .menu-toggle.is-open .hamburger span:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .menu-toggle.is-open .hamburger span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.is-open .hamburger span:nth-child(3) {
    transform: translateY(-4px) rotate(-45deg);
  }

  .wordmark {
    display: flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
  }

  .wordmark-logo {
    height: 26px;
    width: auto;
    display: block;
    mix-blend-mode: multiply;
  }

  .cta-wrap {
    display: flex;
    justify-content: flex-end;
  }

  .cta {
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .cta:hover {
    opacity: 0.55;
  }

  .cta-short {
    display: none;
  }

  @media (max-width: 700px) {
    .top-bar {
      padding: 0 1.25rem;
    }
    .address {
      display: none;
    }
    .menu-toggle {
      display: block;
    }
    .cta-full {
      display: none;
    }
    .cta-short {
      display: inline;
    }
  }
</style>
