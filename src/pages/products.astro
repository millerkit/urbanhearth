---
import { getSiteSettings } from "../lib/site-settings";
import { isSanityConfigured } from "../lib/sanity";
import { fetchAllProducts } from "../lib/sanity-fetch";
import Base from "../layouts/Base.astro";
import AgeGate from "../components/AgeGate.astro";
import PageHeader from "../components/PageHeader.astro";

const restaurant = await getSiteSettings();

type Category = {
  id: string;
  label: string;
  description: string;
  products: any[];
};
let categories: Category[] = [];

if (isSanityConfigured) {
  try {
    const products = await fetchAllProducts();
    // Group by toastGroupGuid, preserving order from the GROQ sort
    // (toastGroupIndex asc, toastSortOrder asc)
    const grouped = new Map<
      string,
      { label: string; description: string; products: any[] }
    >();
    for (const p of products) {
      const key = p.toastGroupGuid ?? "other";
      if (!grouped.has(key)) {
        grouped.set(key, {
          label: p.toastGroupName ?? "Other",
          description: p.toastGroupDescription ?? "",
          products: [],
        });
      }
      grouped.get(key)!.products.push(p);
    }
    categories = [...grouped.entries()].map(([id, group]) => ({
      id,
      label: group.label,
      description: group.description,
      products: group.products,
    }));
  } catch {
    // categories stays empty; coming-soon notice will render
  }
}
---

<Base
  title={`Products — ${restaurant.name}`}
  description="Shop bottled cocktails, bar mixers, and non-alcoholic beverages from Urban Hearth's bar program."
>
  <AgeGate />

  <div class="products-page">
    <PageHeader
      eyebrow="From Our Kitchen & Bar"
      title="Shop"
      lead="Take Urban Hearth home. Food, bottled cocktails, house mixers, and zero-proof drinks — all made in our kitchen."
    />

    {
      categories.length === 0 && (
        <div class="shop-notice">
          <p class="notice-text">
            Online ordering is opening soon.{" "}
            <a
              href={`mailto:${restaurant.privateDiningEmail}`}
              class="notice-link"
            >
              Contact us
            </a>{" "}
            to place an order for pickup.
          </p>
        </div>
      )
    }

    {
      categories.map((cat, i) => (
        <section
          class={`category${i % 2 === 1 ? " category--alt" : ""}`}
          id={cat.id}
        >
          <div class="cat-header">
            <span class="cat-num section-eyebrow">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h2 class="cat-title">{cat.label}</h2>
            <p class="cat-desc">{cat.description}</p>
          </div>

          <div
            class="product-grid"
            style={`--product-cols: ${Math.min(cat.products.length, 4)}`}
          >
            {cat.products.map((p: any) => (
              <div
                class={`product-card${p.available === false ? " product-card--unavailable" : ""}`}
              >
                <div class="product-image-wrap">
                  {p.image ? (
                    <img
                      src={p.image}
                      alt={p.name}
                      class="product-image"
                      loading="lazy"
                    />
                  ) : (
                    <div class="product-image-placeholder" aria-hidden="true" />
                  )}
                  {p.available === false && (
                    <span class="out-of-stock-badge">Out of stock</span>
                  )}
                </div>
                <div class="product-info">
                  <h3 class="product-name">{p.name}</h3>
                  {p.description && <p class="product-note">{p.description}</p>}
                </div>
                <div class="product-footer">
                  <span class="product-price">
                    $
                    {typeof p.price === "number" ? p.price.toFixed(2) : p.price}
                  </span>
                  {p.slug ? (
                    <a href={`/product/${p.slug}`} class="product-cta">
                      View
                    </a>
                  ) : (
                    <button
                      class="product-cta"
                      disabled
                      aria-label={`${p.name} — coming soon`}
                    >
                      Coming Soon
                    </button>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      ))
    }

    <section class="pickup-band">
      <p class="section-eyebrow">Order Ahead</p>
      <p class="pickup-text">
        All products are available for in-restaurant pickup during dining hours.
        Contact us to arrange an order.
      </p>
      <a href={`mailto:${restaurant.privateDiningEmail}`} class="text-cta"
        >Get in touch</a
      >
    </section>
  </div>
</Base>

<style>
  .products-page {
    margin-top: 103px;
  }

  /* ── Coming-soon notice ── */
  .shop-notice {
    background: var(--parchment);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
    text-align: center;
  }

  .notice-text {
    font-family: var(--sans), sans-serif;
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: var(--ink-mid);
  }

  .notice-link {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid rgba(22, 34, 53, 0.3);
    transition: opacity 0.2s;
  }

  .notice-link:hover {
    opacity: 0.6;
  }

  /* ── Category section ── */
  .category {
    border-bottom: 1px solid var(--border);
    padding: 4rem 2.5rem;
  }

  .cat-header {
    max-width: 1100px;
    margin: 0 auto 3rem;
    display: grid;
    grid-template-columns: 40px 1fr;
    grid-template-rows: auto auto;
    column-gap: 1.5rem;
    align-items: start;
  }

  .cat-num {
    grid-row: 1 / 3;
    padding-top: 5px;
    color: var(--ink-light);
  }

  .cat-title {
    font-family: var(--serif), serif;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 300;
    letter-spacing: 0.07em;
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .cat-desc {
    font-family: var(--serif), serif;
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink);
    max-width: 560px;
  }

  /* ── Alternating section backgrounds ── */
  .category {
    background: var(--warm-white);
  }

  .category--alt {
    background: var(--parchment);
  }

  /* Cards contrast against their section: warm-white sections get parchment cards,
     parchment sections get warm-white cards */
  .category--alt .product-card {
    background: var(--warm-white);
  }

  /* ── Product grid ── */
  .product-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(var(--product-cols, 4), minmax(0, 1fr));
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .product-card {
    background: var(--parchment);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
  }

  .product-card--unavailable {
    opacity: 0.65;
  }

  /* ── Product image ── */
  .product-image-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .product-image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center;
    display: block;
    background: var(--parchment);
  }

  .out-of-stock-badge {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    font-family: var(--sans), sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--warm-white);
    background: rgba(22, 34, 53, 0.72);
    padding: 0.3rem 0.6rem;
  }

  /* ── Product info ── */
  .product-info {
    padding: 1.25rem 1.25rem 0.75rem;
    flex: 1;
  }

  .product-name {
    font-family: var(--serif), serif;
    font-size: var(--text-md);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: 0.4rem;
  }

  .product-note {
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-light);
  }

  /* ── Product footer ── */
  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.25rem 1.25rem;
    gap: 1rem;
  }

  .product-price {
    font-family: var(--sans), sans-serif;
    font-size: 0.9375rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--ink);
  }

  .product-cta {
    font-family: var(--sans), sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mid);
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.6rem 1rem;
    text-decoration: none;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  a.product-cta:hover {
    color: var(--ink);
    border-color: rgba(22, 34, 53, 0.4);
  }

  button.product-cta {
    cursor: not-allowed;
    opacity: 0.6;
  }

  /* ── Pickup band ── */
  .pickup-band {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--warm-white);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .pickup-text {
    font-family: var(--serif), serif;
    font-size: var(--text-md);
    font-weight: 300;
    color: var(--ink);
    max-width: 420px;
    line-height: 1.75;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .products-page {
      margin-top: 60px;
    }

    .category {
      padding: 3rem 1.5rem;
    }

    .cat-header {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    .cat-num {
      grid-row: auto;
    }

    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 400px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
