---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import restaurant from '../../content/restaurant.json';
import { isSanityConfigured } from '../../lib/sanity';
import { fetchAllPosts } from '../../lib/sanity-fetch';

export async function getStaticPaths() {
  if (!isSanityConfigured) return [];
  try {
    const { totalPages } = await fetchAllPosts(1, 10);
    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
      params: { page: String(i + 2) },
    }));
  } catch {
    return [];
  }
}

const page = parseInt(Astro.params.page);
let posts: any[] = [];
let totalPages = 1;
if (isSanityConfigured) {
  try {
    ({ posts, totalPages } = await fetchAllPosts(page, 10));
  } catch (e) {
    console.error(`[blog/${page}] fetchAllPosts failed:`, e instanceof Error ? e.message : String(e));
  }
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}

const prevHref = page === 2 ? '/blog' : `/blog/${page - 1}`;
const nextHref = `/blog/${page + 1}`;
---

<Base
  title={`Blog — Page ${page} — ${restaurant.name}`}
  description="News, events, and stories from Urban Hearth."
>
  <div class="blog-page">

    <PageHeader title="Blog" lead="News, events, and stories from the restaurant." />

    <div class="posts-body">
      {posts.length === 0 ? (
        <p class="empty">No posts found.</p>
      ) : (
        <ul class="post-list">
          {posts.map(post => (
            <li class="post-item">
              <a href={`/post/${post.slug}`} class="post-link">
                {post.coverImage && (
                  <div class="post-image-wrap">
                    <img src={post.coverImage} alt={post.title} class="post-image" loading="lazy" />
                  </div>
                )}
                <div class="post-text">
                  {post.publishedAt && <p class="post-date section-eyebrow">{formatDate(post.publishedAt)}</p>}
                  <h2 class="post-title">{post.title}</h2>
                  {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
      <div class="pagination">
        <a href={prevHref} class="text-cta">&larr; Newer</a>
        <span class="page-indicator">Page {page} of {totalPages}</span>
        {page < totalPages && <a href={nextHref} class="text-cta">Older &rarr;</a>}
        {page >= totalPages && <span />}
      </div>
    </div>

  </div>
</Base>

<style>
  .blog-page {
    margin-top: 103px;
  }

  .posts-body {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .empty {
    font-family: var(--serif), serif;
    font-size: var(--text-md);
    font-weight: 300;
    color: var(--ink);
    text-align: center;
    padding: 4rem 0;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
    padding: 2.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .post-link:hover {
    opacity: 0.7;
  }

  .post-link:not(:has(.post-image-wrap)) {
    grid-template-columns: 1fr;
  }

  .post-image-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--parchment);
  }

  .post-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-date {
    margin-bottom: 0.75rem;
  }

  .post-title {
    font-family: var(--serif), serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: 0.9rem;
  }

  .post-excerpt {
    font-family: var(--serif), serif;
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--ink);
    line-height: 1.75;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2.5rem 0 0;
    border-top: 1px solid var(--border);
  }

  .page-indicator {
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  @media (max-width: 600px) {
    .post-link {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
