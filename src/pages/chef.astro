---
import { getSiteSettings } from "../lib/site-settings";
import { isSanityConfigured } from "../lib/sanity";
import { fetchChefProfile } from "../lib/sanity-fetch";
import chefFallback from "../content/chef.json";
import erinFallbackPhoto from "../assets/photos/erin.jpg";
import Base from "../layouts/Base.astro";
import ReservationButton from "../components/ReservationButton.astro";

const restaurant = await getSiteSettings();

let chef = chefFallback;
if (isSanityConfigured) {
  try {
    const data = await fetchChefProfile();
    if (data) chef = data;
  } catch (e) {
    console.error("Failed to fetch chef profile from Sanity:", e);
  }
}

const photoSrc = chef.photo ?? erinFallbackPhoto.src;
---

<Base
  title={`${chef.name} — ${restaurant.name}`}
  description="Erin Miller is the Executive Chef and owner of Urban Hearth. Classically trained, James Beard Finalist, and recognized by the Michelin Guide in 2025."
>
  <div class="chef-page">
    <div class="chef-layout">
      <div class="chef-photo-col">
        <div class="chef-photo-wrap">
          <img src={photoSrc} alt={chef.name} class="chef-photo" />
        </div>
      </div>

      <div class="chef-content-col">
        <div class="chef-content">
          <div class="chef-eyebrow">
            <p class="section-eyebrow">{chef.title}</p>
          </div>

          <h1 class="chef-name">{chef.name}</h1>

          <div class="chef-roles">
            {
              chef.roles.map((role, i) => (
                <>
                  <span>{role}</span>
                  {i < chef.roles.length - 1 && <span class="role-dot">·</span>}
                </>
              ))
            }
          </div>

          <div class="chef-bio">
            {chef.bio.map((paragraph) => <p>{paragraph}</p>)}
          </div>

          <div class="chef-accolades">
            {
              chef.accolades.map((a) => (
                <div class="accolade">
                  <span class="accolade-year">{a.year}</span>
                  <span class="accolade-text">{a.text}</span>
                </div>
              ))
            }
          </div>

          <div class="chef-cta">
            <ReservationButton label="Reserve a table" />
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .chef-page {
    margin-top: 103px;
    min-height: calc(100vh - 103px);
    display: flex;
    flex-direction: column;
  }

  /* ── Split layout ── */
  .chef-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    flex: 1;
  }

  /* ── Photo column ── */
  .chef-photo-col {
    position: sticky;
    top: 103px;
    height: calc(100vh - 103px);
    overflow: hidden;
    background: var(--midnight);
  }

  .chef-photo-wrap {
    width: 100%;
    height: 100%;
  }

  .chef-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    opacity: 0.92;
  }

  /* ── Content column ── */
  .chef-content-col {
    border-left: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
  }

  .chef-content {
    padding: 5rem 4rem 5rem 4.5rem;
    max-width: 580px;
  }

  /* ── Eyebrow ── */
  .chef-eyebrow {
    margin-bottom: 1.8rem;
  }

  /* ── Name ── */
  .chef-name {
    font-family: var(--serif) serif;
    font-size: clamp(2.8rem, 4.5vw, 4.2rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--ink);
    line-height: 1.05;
    margin-bottom: 1.1rem;
  }

  /* ── Roles ── */
  .chef-roles {
    font-family: var(--sans) sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-light);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .role-dot {
    color: var(--border);
  }

  /* ── Bio ── */
  .chef-bio {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin-bottom: 3rem;
  }

  .chef-bio p {
    font-family: var(--serif) serif;
    font-size: var(--text-md);
    font-weight: 300;
    line-height: 1.85;
    color: var(--ink);
  }

  /* ── Accolades ── */
  .chef-accolades {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 3rem;
    border-top: 1px solid var(--border);
  }

  .accolade {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    align-items: baseline;
  }

  .accolade-year {
    font-family: var(--sans) sans-serif;
    font-size: var(--text-label);
    font-weight: 300;
    letter-spacing: 0.14em;
    color: var(--ink-mid);
  }

  .accolade-text {
    font-family: var(--sans) sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  /* ── CTA ── */
  .chef-cta {
    padding-top: 0.5rem;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .chef-layout {
      grid-template-columns: 1fr;
    }

    .chef-photo-col {
      position: static;
      height: 60vw;
      max-height: 480px;
    }

    .chef-content-col {
      border-left: none;
      border-top: 1px solid var(--border);
    }

    .chef-content {
      padding: 3.5rem 2rem 4rem;
      max-width: none;
    }
  }

  @media (max-width: 500px) {
    .chef-content {
      padding: 2.5rem 1.5rem 3rem;
    }

    .chef-bio p {
      font-size: 1.0625rem;
    }
  }
</style>
