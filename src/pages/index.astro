---
import { getSiteSettings } from "../lib/site-settings";

import DiningRoomRendering from "../assets/photos/DiningRoomPhoto.jpeg";
import ChefsCounterRendering from "../assets/photos/ChefsCounterPhoto.png";
import BarRendering from "../assets/photos/SalonPhoto.jpeg";
import michelinSeal from "../assets/ui/michelin-selected.png";
import jamesBeardSeal from "../assets/ui/james-beard-seal.png";
import splashLogo from "../assets/brand/UrbanHearth_Logo_BLACK_cropped.png";
import IntroStatement from "../components/IntroStatement.astro";
import Hero from "../components/Hero.astro";
import Base from "../layouts/Base.astro";
import ReservationButton from "../components/ReservationButton.astro";

const restaurant = await getSiteSettings();
const restaurantJsonLd = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: restaurant.name,
  url: restaurant.url,
  telephone: restaurant.phone,
  address: {
    "@type": "PostalAddress",
    streetAddress: "1281 Cambridge St",
    addressLocality: "Cambridge",
    addressRegion: "MA",
    postalCode: "02139",
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 42.3732,
    longitude: -71.0989,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday",
      ],
      opens: "17:00",
      closes: "22:00",
    },
  ],
  servesCuisine: "New American",
  priceRange: "$$$",
  description: restaurant.tagline,
  hasMap: "https://maps.google.com/?q=1281+Cambridge+St+Cambridge+MA",
  sameAs: [
    restaurant.url,
    restaurant.social.facebook,
    restaurant.social.instagram,
  ],
};
---

<Base title="Urban Hearth — Cambridge, MA">
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(restaurantJsonLd)}
    />
    <script is:inline>
      (function () {
        const KEY = "uh_splash_ts";
        const SEVEN_DAYS = 7 * 24 * 60 * 60 * 1000;
        try {
          const last = localStorage.getItem(KEY);
          if (last && Date.now() - Number(last) < SEVEN_DAYS) {
            const s = document.createElement("style");
            s.textContent = "#splash{display:none!important}";
            document.head.appendChild(s);
          } else {
            localStorage.setItem(KEY, String(Date.now()));
          }
        } catch (_) {}
      })();
    </script>
  </Fragment>
  <div id="splash" aria-hidden="true">
    <img src={splashLogo.src} alt="Urban Hearth" class="splash-logo" />
    <p class="splash-location">
      <span>Inman Square</span>
      <span>Cambridge, Massachusetts</span>
    </p>
  </div>

  <Hero src={DiningRoomRendering} />

  <IntroStatement />

  <section class="dining-teasers">
    <div class="teasers-grid">
      <a href="/dining-areas#dining-room" class="teaser">
        <div class="teaser-photo-wrap">
          <img
            src={DiningRoomRendering.src}
            alt="The Dining Room at Urban Hearth"
            class="teaser-photo"
            loading="eager"
          />
          <div class="teaser-label">
            <span class="teaser-num">01</span>
            <span class="section-eyebrow">À La Carte</span>
          </div>
        </div>
        <div class="teaser-body">
          <h2 class="teaser-title">The Dining Room</h2>
          <p class="teaser-desc">
            Seasonal cooking built around New England farms and fishermen.
            Intimate, unhurried, and always changing.
          </p>
        </div>
      </a>

      <a href="/dining-areas#chefs-counter" class="teaser teaser--dark">
        <div class="teaser-photo-wrap">
          <img
            src={ChefsCounterRendering.src}
            alt="The Chef's Counter at Urban Hearth"
            class="teaser-photo"
            loading="lazy"
          />
          <div class="teaser-label">
            <span class="teaser-num">02</span>
            <span class="section-eyebrow">Prix Fixe</span>
          </div>
        </div>
        <div class="teaser-body">
          <h2 class="teaser-title">The Chef's Counter</h2>
          <p class="teaser-desc">
            Four seats at the kitchen pass. Five courses written that morning.
            An experience for the curious and adventurous.
          </p>
        </div>
      </a>

      <a href="/dining-areas#salon" class="teaser">
        <div class="teaser-photo-wrap">
          <img
            src={BarRendering.src}
            alt="The Salon at Urban Hearth"
            class="teaser-photo"
            loading="lazy"
          />
          <div class="teaser-label">
            <span class="teaser-num">03</span>
            <span class="section-eyebrow">Bar &amp; Lounge</span>
          </div>
        </div>
        <div class="teaser-body">
          <h2 class="teaser-title">The Salon</h2>
          <p class="teaser-desc">
            Natural wines, considered cocktails, and small plates. Walk-ins
            welcome. Open until 11.
          </p>
        </div>
      </a>
    </div>
  </section>

  <section class="booking-band">
    <p class="section-eyebrow">Cambridge, MA</p>
    <p class="booking-tagline">
      Three distinct experiences, each with its own character and pace.
    </p>
    <ReservationButton />
  </section>

  <section class="awards">
    <div class="awards-inner">
      <img src={michelinSeal.src} alt="Michelin Selected" class="award-img" />
      <img src={jamesBeardSeal.src} alt="James Beard Award" class="award-img" />
    </div>
  </section>
</Base>

<style>
  /* ── Dining teasers ── */
  .dining-teasers {
    border-bottom: 1px solid var(--border);
  }

  .teasers-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--border);
  }

  .teaser {
    background: var(--warm-white);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
  }

  .teaser--dark {
    background: var(--midnight);
  }

  .teaser-photo-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--midnight);
    flex-shrink: 0;
  }

  .teaser-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
  }

  .teaser:hover .teaser-photo {
    transform: scale(1.03);
  }

  .teaser-label {
    position: absolute;
    bottom: 1.25rem;
    left: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .teaser-num {
    font-family: var(--sans) sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.5);
  }

  .teaser-label .section-eyebrow {
    color: rgba(255, 255, 255, 0.5);
  }

  .teaser-body {
    padding: 1.75rem 1.75rem 2.25rem;
  }

  .teaser-title {
    font-family: var(--serif) serif;
    font-size: clamp(1.4rem, 2vw, 1.9rem);
    font-weight: 300;
    letter-spacing: 0.06em;
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: 0.9rem;
    transition: opacity 0.2s;
  }

  .teaser:hover .teaser-title {
    opacity: 0.7;
  }

  .teaser--dark .teaser-title {
    color: var(--parchment);
  }

  .teaser-desc {
    font-family: var(--serif) serif;
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-mid);
  }

  .teaser--dark .teaser-desc {
    color: rgba(232, 227, 223, 0.65);
  }

  /* ── Booking band ── */
  .booking-band {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--warm-white);
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .booking-tagline {
    font-family: var(--serif), serif;
    font-size: 1.1875rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink);
    max-width: 420px;
    margin: 0;
  }

  /* ── Awards ── */
  .awards {
    background: var(--warm-white);
    padding: 4.5rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .awards-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .award-img {
    height: 96px;
    width: auto;
    object-fit: contain;
    display: block;
    opacity: 0.8;
  }

  /* ── Responsive ── */
  @media (max-width: 780px) {
    .teasers-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .teaser-body {
      padding: 1.25rem 1.25rem 1.75rem;
    }

    .awards-inner {
      gap: 2.5rem;
    }

    .award-img {
      height: 72px;
    }
  }
</style>

<style is:global>
  /* ── Splash overlay ── */
  #splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--parchment);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    animation: splash-out 0.6s ease 1.6s forwards;
  }

  #splash .splash-logo {
    width: min(240px, 48vw);
    height: auto;
    animation: splash-logo-in 0.7s ease forwards;
  }

  #splash .splash-location {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    margin-top: 2.75rem;
    animation: splash-logo-in 0.7s ease 0.3s both;
  }

  #splash .splash-location span {
    font-family: var(--sans), sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--charcoal);
  }

  @keyframes splash-logo-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes splash-out {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }
</style>

<script>
  const splash = document.getElementById("splash");
  if (splash) {
    splash.addEventListener("animationend", (e) => {
      if (e.animationName === "splash-out") {
        splash.remove();
      }
    });
  }
</script>
