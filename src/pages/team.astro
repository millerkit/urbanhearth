---
import { getSiteSettings } from "../lib/site-settings";
import { isSanityConfigured } from "../lib/sanity";
import { fetchTeamMembers } from "../lib/sanity-fetch";
import teamFallback from "../content/team.json";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";

const restaurant = await getSiteSettings();

let team: typeof teamFallback = teamFallback;
if (isSanityConfigured) {
  try {
    const fetched = await fetchTeamMembers();
    if (fetched?.length) team = fetched;
  } catch (e) {
    console.error("Failed to fetch team members from Sanity:", e);
  }
}
---

<Base
  title={`The Team — ${restaurant.name}`}
  description="Meet the people behind Urban Hearth — the chefs, managers, and front-of-house staff who bring the restaurant to life every night."
>
  <div class="team-page">
    <PageHeader
      title="The Team"
      lead="The people who make the restaurant what it is, every night."
    >
      <p class="team-chef-link">
        Led by <a href="/chef">Erin Miller</a>, Executive Chef &amp; Owner.
      </p>
    </PageHeader>

    <div class="team-grid">
      {
        team.map((member, i) => (
          <article class="member">
            <div class="member-photo-wrap">
              <img
                src={member.photo}
                alt={member.name}
                class="member-photo"
                loading={i < 4 ? "eager" : "lazy"}
              />
            </div>
            <div class="member-info">
              <div class="member-meta">
                <span class="member-index">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="member-roles">
                  {member.roles.map((role, ri) => (
                    <span class="member-role">
                      {role}
                      {ri < member.roles.length - 1 ? (
                        <span class="role-sep">&nbsp;·&nbsp;</span>
                      ) : (
                        ""
                      )}
                    </span>
                  ))}
                </div>
              </div>
              <h2 class="member-name">{member.name}</h2>
              <p class="member-bio">{member.bio}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</Base>

<style>
  .team-page {
    margin-top: 103px;
  }

  .team-chef-link {
    font-family: var(--sans) sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-top: 1.6rem;
  }

  .team-chef-link a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    transition: opacity 0.2s;
  }

  .team-chef-link a:hover {
    opacity: 0.5;
  }

  /* ── Grid ── */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* ── Member card ── */
  .member {
    background: var(--warm-white);
    display: flex;
    flex-direction: column;
  }

  .member-photo-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--parchment);
  }

  .member-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.5s ease;
  }

  .member:hover .member-photo {
    transform: scale(1.03);
  }

  .member-info {
    padding: 1.75rem 1.5rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* ── Meta row ── */
  .member-meta {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .member-index {
    font-family: var(--sans) sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.2em;
    color: var(--ink-light);
    flex-shrink: 0;
    padding-top: 1px;
  }

  .member-roles {
    font-family: var(--sans) sans-serif;
    font-size: var(--text-label);
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mid);
    line-height: 1.6;
  }

  .role-sep {
    color: var(--ink-light);
  }

  /* ── Name ── */
  .member-name {
    font-family: var(--serif) serif;
    font-size: clamp(1.2rem, 1.6vw, 1.55rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: 1rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  /* ── Bio ── */
  .member-bio {
    font-family: var(--sans) sans-serif;
    font-size: 13px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--ink);
    flex: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 1000px) {
    .team-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 420px) {
    .team-grid {
      grid-template-columns: 1fr;
    }

    .member-info {
      padding: 1.5rem 1.25rem 1.75rem;
    }
  }
</style>
