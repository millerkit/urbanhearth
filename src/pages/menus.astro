---
import Base from '../layouts/Base.astro';
import restaurant from '../content/restaurant.json';

const sharedPlates = [
  {
    name: 'Unicorn Oysters on the Half Shell',
    price: '4 ea',
    desc: 'Blueberry vinegar · long pepper mignonette',
  },
  {
    name: 'New England Lamb Beignets',
    price: '8 ea',
    desc: 'Moroccan spiced lamb · lamb heart pastrami · spring herb salad',
  },
  {
    name: 'Hake Crudo in Hibiscus Leche de Tigre',
    price: '26',
    desc: 'Crispy leek · pickled green strawberry · summer truffle',
  },
  {
    name: 'Duck Liver Mousse',
    price: '22',
    desc: 'Blueberry mostarda · pickled radish · pistachio · rye cracker',
  },
  {
    name: 'Vadouvan Carrot Brûlette',
    price: '28',
    desc: 'Savory & butter · sheep maldon · fried mushrooms',
  },
  {
    name: 'Grilled Asparagus & Spring Forage Pistou',
    price: '26',
    desc: 'Cultured sheep\'s milk cheese · basil · fried capers',
  },
  {
    name: 'Blistered Kale with Whipped Tahini',
    price: '28',
    desc: 'Friqule · sichuan sesame crisp · pickled apple · fermented chili',
  },
  {
    name: 'Lovage Crème Brûlée with Sugar Snaps',
    price: '30',
    desc: 'Clothbound cheddar · rye soil · pea tendrils',
  },
  {
    name: 'Juniper Rubbed Swordfish',
    price: '42',
    desc: 'Parsnip crème · blistered grape · tender herbs',
  },
  {
    name: 'Chicken & Wild Mushrooms in Red Wine',
    price: '44',
    desc: 'Thomas Farm · pomelo preserve · pickled onion',
  },
];

const breads = [
  {
    name: 'Warm Mediterranean Olives',
    price: '8',
    desc: 'Olive oil · preserved lemon · chili',
  },
  {
    name: 'Big Buttermilk Biscuit',
    price: '8',
    desc: 'Smoked maple brown butter',
  },
  {
    name: 'Grilled Sourdough Focaccia',
    price: '8',
    desc: 'Du lot spice · olive oil',
  },
  {
    name: 'New England Nosh Board',
    price: '29',
    desc: 'A selection of local cheeses and charcuterie, served with crackers and crudités',
    note: 'Cheeses: hardwood thyme (NH) · camembert (NY) · great hill blue (MA) · jasper hill cheddar (VT) · truffle manchego (VT) — Charcuterie: mortadella · prosciutto di parma · n\'duja',
  },
];

---

<Base
  title={`Our Menus — ${restaurant.name}`}
  description="The Spring 2026 menu at Urban Hearth. Seasonal à la carte dining and a nightly five-course Chef's Tasting Menu."
>
  <div class="menus-page">

    <header class="menus-header">
      <p class="section-eyebrow">Spring 2026</p>
      <h1>Our Menus</h1>
      <p class="menus-lead">Seasonal cooking, sourced from a close network of New England farms and fishermen.</p>
    </header>

    <div class="menus-layout">

      <!-- ── À la carte ── -->
      <div class="menu-main">

        <div class="menu-dining-room">
          <div class="dining-room-text">
            <p class="section-eyebrow">Dining Room</p>
            <p class="dining-room-hours">Monday – Saturday, 5:00 – 10:00 pm. Walk-ins welcome; reservations recommended.</p>
          </div>
          <a href={`${restaurant.reservations.href}#dining-room`} class="text-cta">Reserve a table</a>
        </div>

        <section class="menu-section">
          <h2 class="menu-section-title">Shared Plates</h2>
          <ul class="dish-list">
            {sharedPlates.map(dish => (
              <li class="dish">
                <div class="dish-top">
                  <span class="dish-name">{dish.name}</span>
                  <span class="dish-price">{dish.price}</span>
                </div>
                <p class="dish-desc">{dish.desc}</p>
              </li>
            ))}
          </ul>
        </section>

        <section class="menu-section">
          <h2 class="menu-section-title">Breads &amp; Charcuterie</h2>
          <ul class="dish-list">
            {breads.map(dish => (
              <li class="dish">
                <div class="dish-top">
                  <span class="dish-name">{dish.name}</span>
                  <span class="dish-price">{dish.price}</span>
                </div>
                <p class="dish-desc">{dish.desc}</p>
                {dish.note && <p class="dish-note">{dish.note}</p>}
              </li>
            ))}
          </ul>
        </section>

        <p class="menu-footer-note">Ask your server to see our dessert menu. Please inform your server of any dietary restrictions. A 20% gratuity is added for parties of six or more.</p>

      </div>

      <!-- ── Sidebar ── -->
      <aside class="menu-sidebar">

        <div class="sidebar-card sidebar-card--dark">
          <p class="sidebar-eyebrow section-eyebrow">Chef's Counter</p>
          <div class="sidebar-price">$160 <span>per person</span></div>
          <p class="sidebar-desc">A five-course interactive dining experience at our Chef's Counter. The menu changes nightly, shaped by what arrived that morning.</p>
          <div class="sidebar-sub">
            <span class="sidebar-sub-label">Wine pairing</span>
            <span class="sidebar-sub-value">+$70 per person</span>
          </div>
          <ul class="tasting-courses">
            <li class="tasting-course">
              <span class="course-label">I</span>
              <span class="course-name">Amuse-Bouche</span>
            </li>
            <li class="tasting-course">
              <span class="course-label">II</span>
              <span class="course-name">Crudo &amp; Garden</span>
              <span class="course-desc">Raw or lightly cured fish · seasonal vegetable · cold pressed oil</span>
            </li>
            <li class="tasting-course">
              <span class="course-label">III</span>
              <span class="course-name">The Hearth Course</span>
              <span class="course-desc">Wood-fired preparation · preserved element · fermented accent</span>
            </li>
            <li class="tasting-course">
              <span class="course-label">IV</span>
              <span class="course-name">Land &amp; Sea</span>
              <span class="course-desc">Primary protein · root vegetable · foraged herb</span>
            </li>
            <li class="tasting-course">
              <span class="course-label">V</span>
              <span class="course-name">Sweets</span>
              <span class="course-desc">Seasonal dessert · mignardises</span>
            </li>
          </ul>
          <p class="sidebar-note">Advanced reservations required. As the menu changes nightly, we cannot guarantee accommodation of all dietary restrictions.</p>
          <a href={`${restaurant.reservations.href}#chefs-counter`} class="sidebar-cta">Reserve your seat</a>
        </div>


      </aside>

    </div>
  </div>
</Base>

<style>
  .menus-page {
    margin-top: 103px;
  }

  /* ── Header ── */
  .menus-header {
    text-align: center;
    padding: 5rem 2rem 4rem;
    border-bottom: 1px solid var(--border);
    background: var(--warm-white);
  }

  .menus-header .section-eyebrow {
    margin-bottom: 1.4rem;
  }

  .menus-header h1 {
    font-family: var(--serif);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .menus-lead {
    font-family: var(--serif), serif;
    font-size: 18px;
    font-weight: 300;
    color: var(--ink-mid);
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Two-column layout ── */
  .menus-layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1px;
    background: var(--border);
    align-items: start;
  }

  /* ── Dining room banner ── */
  .menu-dining-room {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.5rem 0 2rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .menu-dining-room .section-eyebrow {
    margin-bottom: 0.5rem;
  }

  .dining-room-hours {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.6;
  }

  /* ── Main menu column ── */
  .menu-main {
    background: var(--warm-white);
    padding: 4rem 3.5rem 4rem 4rem;
  }

  .menu-section {
    margin-bottom: 3.5rem;
  }

  .menu-section:last-of-type {
    margin-bottom: 2.5rem;
  }

  .menu-section-title {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  /* ── Dish list ── */
  .dish-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dish {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .dish:first-child {
    border-top: none;
  }

  .dish-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 0.4rem;
  }

  .dish-name {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 300;
    letter-spacing: 0.02em;
    color: var(--ink);
    line-height: 1.3;
  }

  .dish-price {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 300;
    color: var(--ink-mid);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dish-desc {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--ink-mid);
    line-height: 1.6;
    text-transform: lowercase;
  }

  .dish-note {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-light);
    line-height: 1.7;
    margin-top: 0.5rem;
  }

  /* ── Footer note ── */
  .menu-footer-note {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-light);
    line-height: 1.7;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  /* ── Sidebar ── */
  .menu-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
  }

  .sidebar-card {
    background: var(--warm-white);
    padding: 2.5rem 2rem;
  }

  .sidebar-card--dark {
    background: var(--midnight);
  }

  .sidebar-eyebrow {
    margin-bottom: 1.2rem;
  }

  .sidebar-card--dark .sidebar-eyebrow {
    color: rgba(255, 255, 255, 0.4);
  }

  .sidebar-price {
    font-family: var(--serif);
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--parchment);
    line-height: 1;
    margin-bottom: 1.2rem;
  }

  .sidebar-price span {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.1em;
  }

  .sidebar-desc {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  .sidebar-card--dark .sidebar-desc {
    color: rgba(232, 227, 223, 0.75);
  }

  .sidebar-sub {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.75rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    margin-bottom: 1.2rem;
  }

  .sidebar-sub-label {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.38);
  }

  .sidebar-sub-value {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 300;
    color: var(--parchment);
  }

  /* ── Tasting courses ── */
  .tasting-courses {
    list-style: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 1.5rem;
  }

  .tasting-course {
    display: grid;
    grid-template-columns: 1.4rem 1fr;
    column-gap: 0.75rem;
    row-gap: 0.2rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .course-label {
    font-family: var(--sans);
    font-size: 9px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    padding-top: 0.2rem;
    grid-row: 1 / 3;
    align-self: start;
  }

  .course-name {
    font-family: var(--serif);
    font-size: 14px;
    font-weight: 300;
    color: var(--parchment);
    letter-spacing: 0.03em;
    line-height: 1.3;
  }

  .course-desc {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.5;
    text-transform: lowercase;
    grid-column: 2;
  }

  .sidebar-note {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    font-style: italic;
    color: rgba(255, 255, 255, 0.3);
    line-height: 1.7;
    margin-bottom: 1.8rem;
  }

  .sidebar-cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--parchment);
    text-decoration: none;
    border-bottom: 1px solid rgba(232, 227, 223, 0.4);
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .sidebar-cta:hover {
    opacity: 0.6;
  }

  /* ── Farms ── */
  .sidebar-farms-intro {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }

  .farms-list {
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .farms-list li {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 300;
    color: var(--ink);
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
    letter-spacing: 0.04em;
  }

  /* ── Reserve card ── */
  .sidebar-card--reserve .sidebar-desc {
    margin-bottom: 1.5rem;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .menus-layout {
      grid-template-columns: 1fr;
    }

    .menu-main {
      padding: 3rem 2rem;
    }

    .menu-sidebar {
      border-top: 1px solid var(--border);
    }
  }

  @media (max-width: 500px) {
    .menu-main {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
