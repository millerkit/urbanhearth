---
import Base from '../layouts/Base.astro';
import restaurant from '../content/restaurant.json';
import RestaurantHours from '../components/RestaurantHours.astro';
import ReservationButton from '../components/ReservationButton.astro';
import PageHeader from '../components/PageHeader.astro';
import ChefsCounter from '../components/ChefsCounter.astro';
import { isStoryblokConfigured } from '../lib/storyblok';
import { fetchMenu } from '../lib/storyblok-fetch';
import { staticMenuSections } from '../content/static-menus.ts';
import '../styles/menu-shared.css';

// Fetch from Storyblok (falls back to static if not connected)
console.log('[menus] isStoryblokConfigured:', isStoryblokConfigured);
let cmsMenu = null;
if (isStoryblokConfigured) {
  try {
    cmsMenu = await fetchMenu();
    console.log('[menus] cmsMenu:', JSON.stringify(cmsMenu));
  } catch (e) {
    console.error('[menus] fetch error:', e);
  }
}

const season   = cmsMenu?.season   ?? 'Spring 2026';
const sections = cmsMenu?.sections ?? staticMenuSections;
---

<Base
  title={`Our Menus \u2014 ${restaurant.name}`}
  description="The Spring 2026 menu at Urban Hearth. Seasonal à la carte dining and a nightly five-course Chef's Tasting Menu."
>
  <div class="menus-page">

    <PageHeader eyebrow={season} title="Our Menus" lead="Seasonal cooking from New England farms and fishermen." />

    <div class="menus-layout">

      <!-- ── À la carte ── -->
      <div class="menu-main menu-card">

        <div class="menu-dining-room">
          <div class="dining-room-text">
            <p class="menu-eyebrow">Dining Room</p>
            <RestaurantHours class="dining-room-hours" />
            <p class="dining-room-hours">Walk-ins welcome; reservations recommended.</p>
          </div>
          <ReservationButton href={`${restaurant.reservations.href}#dining-room`} label="Reserve a table" />
        </div>

        {sections.map((section: { title: unknown; items: any[]; }) => (
          <section class="menu-section">
            <h2 class="menu-label menu-section-title">{section.title}</h2>
            <ul class="dish-list">
              {section.items.map(dish => (
                <li class="dish">
                  <div class="dish-top">
                    <span class="dish-name">{dish.name}</span>
                    <span class="dish-price">{dish.price}</span>
                  </div>
                  {dish.description && <p class="dish-desc">{dish.description}</p>}
                  {dish.note        && <p class="menu-fine-print dish-note">{dish.note}</p>}
                </li>
              ))}
            </ul>
          </section>
        ))}

        <p class="menu-fine-print menu-footer-note">Ask your server to see our dessert menu. Please inform your server of any dietary restrictions. A 20% gratuity is added for parties of six or more.</p>

      </div>

      <!-- ── Chef's Counter ── -->
      <aside class="menu-sidebar">
        <ChefsCounter />
      </aside>

    </div>
  </div>
</Base>

<style>
  .menus-page {
    margin-top: 103px;
  }

  /* ── Layout ── */
  .menus-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    max-width: 1200px;
    margin: 4rem auto;
    padding: 0 2.5rem;
    gap: 3rem;
  }

  /* ── Main card ── */
  .menu-main {
    padding: 2.5rem 3rem 3rem;
  }

  /* ── Dining room header ── */
  .menu-dining-room {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 0 0 2rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .dining-room-hours {
    font-family: var(--sans), sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.6;
  }

  /* ── Menu sections ── */
  .menu-section {
    margin-bottom: 3.5rem;
  }

  .menu-section:last-of-type {
    margin-bottom: 2.5rem;
  }

  .menu-section-title {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  /* ── Dish list ── */
  .dish-list {
    list-style: none;
  }

  .dish {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .dish-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 0.4rem;
  }

  .dish-price {
    font-family: var(--sans), sans-serif;
    font-size: 16px;
    font-weight: 300;
    color: var(--ink-mid);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dish-note {
    margin-top: 0.5rem;
  }

  /* ── Footer note ── */
  .menu-footer-note {
    font-size: 12px;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .menus-layout {
      grid-template-columns: 1fr;
      margin: 2.5rem auto;
      padding: 0 1.5rem;
      gap: 2rem;
    }

    .menu-main {
      padding: 2.5rem 2rem;
    }
  }

  @media (max-width: 500px) {
    .menus-layout {
      padding: 0 1rem;
    }

    .menu-main {
      padding: 2rem 1.25rem;
    }
  }
</style>
