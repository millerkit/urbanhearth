---
import { getSiteSettings } from "../lib/site-settings";
import { isSanityConfigured } from "../lib/sanity";
import { fetchGalleryPhotos } from "../lib/sanity-fetch";
import galleryFallback from "../content/gallery.json";
import food1 from "../assets/photos/food-photo-1.jpeg";
import food2 from "../assets/photos/food-photo-2.jpeg";
import food4 from "../assets/photos/food-photo-4.jpeg";
import food5 from "../assets/photos/food-photo-5.jpeg";
import food6 from "../assets/photos/food-photo-6.jpeg";
import g007 from "../assets/gallery/gallery-007.jpg";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";

// Layout spans: 'full' = spans all 3 cols, 'wide' = 2 cols, 'normal' = 1 col
// Rows are implicit — browser fills gaps
const restaurant = await getSiteSettings();

// Ordered fallbacks matching gallery.json (index 0 = order 1, etc.)
const photoFallbacks = [
  food1.src,
  food2.src,
  food4.src,
  food5.src,
  food6.src,
  g007.src,
];

let items = galleryFallback;
if (isSanityConfigured) {
  try {
    const data = await fetchGalleryPhotos();
    if (data?.length) items = data;
  } catch (e) {
    console.error("Failed to fetch gallery photos from Sanity:", e);
  }
}

const photos = items.map((item, i) => ({
  src: item.photo ?? photoFallbacks[i],
  alt: item.alt,
  span: item.span,
}));
---

<Base
  title={`Gallery — ${restaurant.name}`}
  description="Images from Urban Hearth — the kitchen, the dining room, and the New England landscape that shapes our cooking."
>
  <div class="gallery-page">
    <PageHeader title="Gallery" />

    <div class="gallery-grid">
      {
        photos.map((photo, i) => (
          <div class={`gallery-item gallery-item--${photo.span}`}>
            <img
              src={photo.src}
              alt={photo.alt}
              loading={i < 4 ? "eager" : "lazy"}
            />
          </div>
        ))
      }
    </div>
  </div>
</Base>

<style>
  .gallery-page {
    margin-top: 103px;
  }

  /* ── Grid ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    background: var(--border);
    border-bottom: 1px solid var(--border);
  }

  .gallery-item {
    overflow: hidden;
    background: var(--parchment);
    aspect-ratio: 4 / 5;
  }

  .gallery-item--wide {
    grid-column: span 2;
    aspect-ratio: 16 / 9;
  }

  .gallery-item--full {
    grid-column: span 3;
    aspect-ratio: 21 / 9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-item--wide {
      grid-column: span 2;
      aspect-ratio: 4 / 3;
    }

    .gallery-item--full {
      grid-column: span 2;
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 440px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .gallery-item,
    .gallery-item--wide,
    .gallery-item--full {
      grid-column: span 1;
      aspect-ratio: 4 / 3;
    }
  }
</style>
