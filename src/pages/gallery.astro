---
import Base from '../layouts/Base.astro';
import restaurant from '../content/restaurant.json';

import g000 from '../assets/gallery/gallery-000.jpg';
import g001 from '../assets/gallery/gallery-001.jpg';
import g002 from '../assets/gallery/gallery-002.jpg';
import g004 from '../assets/gallery/gallery-004.jpg';
import g005 from '../assets/gallery/gallery-005.jpg';
import g006 from '../assets/gallery/gallery-006.jpg';
import g007 from '../assets/gallery/gallery-007.jpg';
import g008 from '../assets/gallery/gallery-008.jpg';
import g009 from '../assets/gallery/gallery-009.jpg';

import food1 from '../assets/photos/food-photo-1.jpeg';
import food2 from '../assets/photos/food-photo-2.jpeg';
import food4 from '../assets/photos/food-photo-4.jpeg';
import food5 from '../assets/photos/food-photo-5.jpeg';
import food6 from '../assets/photos/food-photo-6.jpeg';

// Layout spans: 'full' = spans all 3 cols, 'wide' = 2 cols, 'normal' = 1 col
// Rows are implicit — browser fills gaps
const photos = [
  { src: g002.src, alt: 'The dining room, set for service', span: 'wide' },
  { src: g000.src, alt: 'Foraging in New England', span: 'normal' },
  { src: food1.src, alt: 'Seasonal small plate', span: 'normal' },
  { src: g001.src, alt: 'Finishing a dish at the pass', span: 'normal' },
  { src: food2.src, alt: 'From the kitchen', span: 'normal' },
  { src: g007.src, alt: 'Dried botanicals', span: 'normal' },
  { src: food4.src, alt: 'Seasonal plate', span: 'normal' },
  { src: g005.src, alt: 'Late summer fruit', span: 'normal' },
  { src: g008.src, alt: 'Roasted bird with herbs and mushrooms', span: 'normal' },
  { src: food5.src, alt: 'Kitchen preparation', span: 'normal' },
  { src: g009.src, alt: 'Pasta in broth', span: 'normal' },
  { src: food6.src, alt: 'A course from the Chef\'s Counter', span: 'normal' },
  { src: g004.src, alt: 'Foraging with the team', span: 'wide' },
  { src: g006.src, alt: 'New England coastline', span: 'normal' },
];
---

<Base
  title={`Gallery — ${restaurant.name}`}
  description="Images from Urban Hearth — the kitchen, the dining room, and the New England landscape that shapes our cooking."
>
  <div class="gallery-page">

    <header class="gallery-header page-header">
      <p class="section-eyebrow">Cambridge, MA</p>
      <h1>Gallery</h1>
    </header>

    <div class="gallery-grid">
      {photos.map((photo, i) => (
        <div class={`gallery-item gallery-item--${photo.span}`}>
          <img
            src={photo.src}
            alt={photo.alt}
            loading={i < 4 ? 'eager' : 'lazy'}
          />
        </div>
      ))}
    </div>

  </div>
</Base>

<style>
  .gallery-page {
    margin-top: 103px;
  }

  /* ── Header ── */
  .gallery-header {
    text-align: center;
    padding: 5rem 2rem 4rem;
    border-bottom: 1px solid var(--border);
    background: var(--warm-white);
  }

  .gallery-header .section-eyebrow {
    margin-bottom: 1.4rem;
  }


  /* ── Grid ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    background: var(--border);
    border-bottom: 1px solid var(--border);
  }

  .gallery-item {
    overflow: hidden;
    background: var(--parchment);
    aspect-ratio: 4 / 5;
  }

  .gallery-item--wide {
    grid-column: span 2;
    aspect-ratio: 16 / 9;
  }

  .gallery-item--full {
    grid-column: span 3;
    aspect-ratio: 21 / 9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-item--wide {
      grid-column: span 2;
      aspect-ratio: 4 / 3;
    }

    .gallery-item--full {
      grid-column: span 2;
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 440px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .gallery-item,
    .gallery-item--wide,
    .gallery-item--full {
      grid-column: span 1;
      aspect-ratio: 4 / 3;
    }
  }
</style>
