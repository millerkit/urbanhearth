---
import Base from '../../layouts/Base.astro';
import restaurant from '../../content/restaurant.json';
import { isStoryblokConfigured } from '../../lib/storyblok';
import { fetchPostBySlug, fetchAllPostSlugs } from '../../lib/storyblok-fetch';

export async function getStaticPaths() {
  if (!isStoryblokConfigured) return [];
  let slugs: string[] = [];
  try {
    slugs = await fetchAllPostSlugs();
  } catch {
    // fetch failed
  }
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = isStoryblokConfigured ? await fetchPostBySlug(slug!) : null;

if (!post) return Astro.redirect('/happenings');

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}
---

<Base
  title={`${post.title} — ${restaurant.name}`}
  description={post.excerpt ?? `A post from Urban Hearth.`}
>
  <div class="post-page">

    <div class="post-header">
      {post.publishedAt && <p class="section-eyebrow post-date">{formatDate(post.publishedAt)}</p>}
      <h1>{post.title}</h1>
      {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
    </div>

    {post.coverImage && (
      <div class="post-cover">
        <img src={post.coverImage} alt={post.title} />
      </div>
    )}

    <div class="post-body" set:html={post.body} />

    <div class="post-back">
      <a href="/happenings" class="text-cta">← All happenings</a>
    </div>

  </div>
</Base>

<style>
  .post-page {
    margin-top: 103px;
  }

  /* ── Header ── */
  .post-header {
    text-align: center;
    padding: 3.5rem 2rem 2.5rem;
    border-bottom: 1px solid var(--border);
    background: var(--warm-white);
  }

  .post-date {
    margin-bottom: 1.2rem;
  }

  .post-header h1 {
    font-family: var(--serif), serif;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--ink);
    line-height: 1.15;
    max-width: 760px;
    margin: 0 auto 1.5rem;
  }

  .post-excerpt {
    font-family: var(--serif), serif;
    font-size: 18px;
    font-weight: 300;
    color: var(--ink-mid);
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Cover image ── */
  .post-cover {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Body ── */
  .post-body {
    max-width: 680px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .post-body :global(p) {
    font-family: var(--serif), serif;
    font-size: 18px;
    font-weight: 300;
    line-height: 1.85;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  .post-body :global(h2) {
    font-family: var(--serif), serif;
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--ink);
    margin: 2.5rem 0 1rem;
  }

  .post-body :global(h3) {
    font-family: var(--sans), sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--border);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--ink-mid);
  }

  /* ── Back link ── */
  .post-back {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
</style>
